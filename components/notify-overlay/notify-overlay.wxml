<view class="overlay-mask" wx:if="{{visible}}" bindtap="onTap" catchtouchmove="noop">
  <view class="overlay-card" catchtap="onTap">
    <text class="overlay-icon">🔔</text>
    <text class="overlay-title">通知授权需更新</text>
    <text class="overlay-desc" wx:if="{{reason}}">因{{reason}}，需重新授权通知。点击任意位置开始授权。</text>
  </view>
</view>
