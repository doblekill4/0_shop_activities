/* pages/admin/permissions/permissions.wxss */
.admin-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.admin-scroll { flex: 1; }

.tip-banner {
  background: #E3F2FD;
  padding: 20rpx 28rpx;
  margin: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #1565C0;
}

.group-card { margin: 12rpx 24rpx; }

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.group-info { display: flex; flex-direction: column; gap: 4rpx; }
.group-name  { font-size: 30rpx; font-weight: 700; color: #222; }
.group-count { font-size: 22rpx; color: #888; }

.group-actions { display: flex; gap: 12rpx; }

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #E8F5E9;
  color: #2E7D32;
  font-size: 24rpx;
}

.action-btn.danger { background: #FFEBEE; color: #D32F2F; }

/* 权限开关列表 */
.perm-list { display: flex; flex-direction: column; gap: 0; }

.perm-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.perm-toggle:last-child { border-bottom: none; }
.perm-name { font-size: 26rpx; color: #333; }

/* 开关 */
.toggle-switch {
  width: 80rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #ccc;
  position: relative;
  transition: background 0.2s;
}

.toggle-switch.on { background: #2E7D32; }

.toggle-thumb {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fff;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.2s;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.2);
}

.toggle-switch.on .toggle-thumb { left: 40rpx; }

/* 新建按钮 */
.add-group-btn {
  margin: 16rpx 24rpx 40rpx;
  background: #ffffff;
  border: 2rpx dashed #2E7D32;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 600;
}
