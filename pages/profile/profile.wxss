/* pages/profile/profile.wxss */
.profile-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 60rpx 32rpx 40rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.user-info { display: flex; flex-direction: column; gap: 8rpx; }
.user-name { font-size: 36rpx; font-weight: 700; color: #ffffff; }
.user-dept { font-size: 24rpx; color: rgba(255,255,255,0.8); }

.role-tag {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
  margin-top: 4rpx;
}

.profile-scroll { flex: 1; }
.section-card { margin: 16rpx 24rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #222; margin-bottom: 16rpx; display: block; }

/* 权限网格 */
.perm-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.perm-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.perm-item.has  { background: #E8F5E9; color: #2E7D32; }
.perm-item.no   { background: #fafafa; color: #ccc; }

.perm-icon { font-size: 20rpx; }
.perm-label {}

/* 菜单列表 */
.menu-list { display: flex; flex-direction: column; }

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child { border-bottom: none; }
.menu-icon  { font-size: 36rpx; }
.menu-label { flex: 1; font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 32rpx; color: #ccc; }
.menu-val   { font-size: 24rpx; color: #888; }

/* 退出 */
.logout-btn {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  color: #D32F2F;
  font-weight: 600;
}
