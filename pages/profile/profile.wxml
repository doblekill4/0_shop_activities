<!-- pages/profile/profile.wxml -->
<view class="profile-page">

  <!-- 用户信息头部 -->
  <view class="user-header bg-primary">
    <image class="user-avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '未登录'}}</text>
      <text class="user-dept">{{userInfo.department || '—'}}</text>
      <view class="role-tag">{{userInfo.roleLabel}}</view>
    </view>
  </view>

  <scroll-view scroll-y class="profile-scroll">

    <!-- 我的权限 -->
    <view class="card section-card">
      <text class="section-title">我的权限</text>
      <view class="perm-grid">
        <view class="perm-item {{item.has ? 'has' : 'no'}}"
          wx:for="{{permList}}" wx:key="key">
          <text class="perm-icon">{{item.has ? '✓' : '✗'}}</text>
          <text class="perm-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 管理员入口（细粒度权限控制） -->
    <view class="card section-card" wx:if="{{isAdmin}}">
      <text class="section-title">管理员功能</text>
      <view class="menu-list">
        <view class="menu-item" bindtap="goPermissions" wx:if="{{permFlags.manageUsers}}">
          <text class="menu-icon">🔐</text>
          <text class="menu-label">权限组管理</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goDepartments" wx:if="{{permFlags.manageDepartments}}">
          <text class="menu-icon">🏢</text>
          <text class="menu-label">部门群组管理</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goExport" wx:if="{{permFlags.exportData}}">
          <text class="menu-icon">📤</text>
          <text class="menu-label">数据导出</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goNotificationConfig" wx:if="{{permFlags.sendNotification}}">
          <text class="menu-icon">🔔</text>
          <text class="menu-label">通知配置</text>
          <text class="menu-arrow">›</text>
        </view>
        <button class="menu-item share-btn" open-type="share">
          <text class="menu-icon">📤</text>
          <text class="menu-label">分享小程序到群</text>
          <text class="menu-arrow">›</text>
        </button>
        <view class="menu-item" bindtap="goUserManage" wx:if="{{isAdmin}}">
          <text class="menu-icon">👥</text>
          <text class="menu-label">员工管理</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="activateStoreGroup" wx:if="{{userInfo.name === '王万全'}}">
          <text class="menu-icon">🔒</text>
          <text class="menu-label">激活门店群白名单</text>
          <text class="menu-val">体验版手动</text>
        </view>
        <view class="menu-item" bindtap="resetStoreGroup" wx:if="{{userInfo.name === '王万全'}}">
          <text class="menu-icon">🔄</text>
          <text class="menu-label">重置门店群白名单</text>
          <text class="menu-val">仅王万全</text>
        </view>
        <view class="menu-item test-btn" bindtap="testNotify" wx:if="{{userInfo.name === '王万全'}}">
          <text class="menu-icon">🧪</text>
          <text class="menu-label">通知系统测试</text>
          <text class="menu-val">发送测试</text>
        </view>
      </view>
    </view>

    <!-- 接待上限（有权用户可见） -->
    <view class="card section-card" wx:if="{{permFlags.capacityLimit}}">
      <text class="section-title">接待管理</text>
      <view class="menu-list">
        <picker mode="date" value="{{capacityDate}}" bindchange="onCapacityDatePick">
          <view class="menu-item">
            <text class="menu-icon">🚫</text>
            <text class="menu-label">标记接待上限</text>
            <text class="menu-arrow">›</text>
          </view>
        </picker>
        <picker mode="date" value="{{capacityDate}}" bindchange="onCapacityDateUnmark">
          <view class="menu-item">
            <text class="menu-icon">✅</text>
            <text class="menu-label">取消上限标记</text>
            <text class="menu-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 通知设置 -->
    <view class="card section-card">
      <text class="section-title">通知设置</text>
      <view class="menu-list">
        <view class="menu-item" bindtap="toggleNotify">
          <text class="menu-icon">🔔</text>
          <text class="menu-label">接收活动通知</text>
          <switch checked="{{notifyEnabled}}" color="#2E7D32" disabled />
        </view>
        <view class="notify-status" wx:if="{{notifyAuthAt}}">
          <view class="notify-status-row">
            <text class="ns-label">上次授权</text>
            <text class="ns-value">{{notifyAuthAt}}</text>
          </view>
          <view class="notify-status-row" wx:if="{{notifyAuthVersion}}">
            <text class="ns-label">授权版本</text>
            <text class="ns-value {{notifyAuthVersion !== appVersion ? 'ns-mismatch' : ''}}">{{notifyAuthVersion}} {{notifyAuthVersion !== appVersion ? '⚠需更新' : '✓'}}</text>
          </view>
          <view class="notify-status-row">
            <text class="ns-label">已发送</text>
            <text class="ns-value">{{notifySentCount}} 条</text>
          </view>
          <view class="notify-status-row error" wx:if="{{notifyLastError}}">
            <text class="ns-label">最近错误</text>
            <text class="ns-value" selectable="true">{{notifyLastError}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 关于 -->
    <view class="card section-card">
      <view class="menu-list">
        <view class="menu-item">
          <text class="menu-icon">📱</text>
          <text class="menu-label">版本</text>
          <text class="menu-val">v{{appVersion}}</text>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-btn" bindtap="logout">
      <text>退出登录</text>
    </view>

    <view style="height: 60rpx;" />
  </scroll-view>

</view>
