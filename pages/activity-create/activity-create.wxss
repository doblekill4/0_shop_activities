/* pages/activity-create/activity-create.wxss */
.create-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.form-scroll { flex: 1; }

/* ========== 活动日历 ========== */
.calendar-section {
  padding: 16rpx 20rpx;
}
.cal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.cal-nav-arrow {
  width: 60rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #2E7D32;
  font-weight: 300;
}
.cal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}
.cal-weekdays {
  display: flex;
  margin-bottom: 4rpx;
}
.cal-wd {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #888;
  padding: 8rpx 0;
}
.cal-grid {
  display: flex;
}
.cal-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  margin: 2rpx;
  font-size: 22rpx;
  position: relative;
  flex-shrink: 0;
}
.cal-empty { background: transparent; }
.cal-green { background: #C8E6C9; }
.cal-yellow { background: #FFF9C4; }
.cal-purple { background: #E1BEE7; }
.cal-today {
  border: 3rpx solid #1976D2;
  border-radius: 8rpx;
}
.cal-day { font-size: 28rpx; font-weight: 600; color: #333; }
.cal-count { font-size: 20rpx; color: #555; line-height: 1.3; }
.cal-people { font-size: 18rpx; color: #888; line-height: 1.2; }
.cal-legend {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}
.cal-lg-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #888;
}
.cal-lg-dot { width: 20rpx; height: 20rpx; border-radius: 4rpx; flex-shrink: 0; }
.cal-green-dot { background: #C8E6C9; border: 1rpx solid #A5D6A7; }
.cal-yellow-dot { background: #FFF9C4; border: 1rpx solid #FFF176; }
.cal-purple-dot { background: #E1BEE7; border: 1rpx solid #CE93D8; }

/* 提示横幅 */
.banner-tip {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  background: #FFF8E1;
  border-left: 6rpx solid #FFC107;
  padding: 20rpx 24rpx;
  margin: 16rpx 24rpx;
  border-radius: 8rpx;
}

.tip-icon { font-size: 28rpx; flex-shrink: 0; }
.tip-text { font-size: 24rpx; color: #6D4C41; line-height: 1.6; }

/* ========== 粘贴识别区域 ========== */
.paste-section {
  margin: 16rpx 24rpx;
  background: #F0F7FF;
  border: 2rpx solid #BBDEFB;
  border-radius: 16rpx;
  padding: 24rpx;
}

.paste-section .section-header {
  margin-bottom: 16rpx;
}

.paste-hint {
  font-size: 22rpx;
  color: #1976D2;
  background: #E3F2FD;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.paste-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.8;
  box-sizing: border-box;
}

.btn-parse {
  width: 100%;
  margin-top: 20rpx;
  background: #1976D2;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx;
  padding: 20rpx 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-parse[disabled] {
  background: #BBDEFB;
  color: #90CAF9;
}

/* ========== 分区 ========== */
.form-section { margin: 16rpx 24rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title  { font-size: 30rpx; font-weight: 700; color: #222; margin-bottom: 20rpx; display: block; }

.form-textarea { min-height: 120rpx; line-height: 1.7; }

.picker-value { color: #333; }
.picker-value.placeholder { color: #bbb; }

/* 环节表单 */
.add-step-btn {
  background: #E8F5E9;
  color: #2E7D32;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.step-form-list { display: flex; flex-direction: column; gap: 20rpx; }

.step-form-item {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  background: #fafafa;
}

.step-form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.step-form-num { font-size: 26rpx; font-weight: 600; color: #2E7D32; }

.step-remove {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #FFEBEE;
  color: #D32F2F;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.step-row  { display: flex; gap: 16rpx; }
.flex-1    { flex: 1; }

.step-time-row {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
}

.flex-half      { flex: 1; }
.step-time-sep  { font-size: 28rpx; color: #888; padding-bottom: 20rpx; }

/* 场地需求切换 */
.need-toggle-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.need-toggle {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 4rpx;
  border-radius: 12rpx;
  background: transparent;
  border: 2rpx solid #e0e0e0;
  font-size: 22rpx;
  color: #aaa;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.need-toggle .need-icon {
  filter: grayscale(100%);
  opacity: 0.35;
}

.need-toggle.active {
  background: rgba(46, 125, 50, 0.1);
  border-color: #2E7D32;
  color: #2E7D32;
  font-weight: 500;
}

.need-toggle.active .need-icon {
  filter: none;
  opacity: 1;
}

.need-icon { font-size: 36rpx; }

/* 香囊 */
.sachet-section { border: 2rpx solid #FFC107; background: #FFFDE7; }

.warn-tag {
  font-size: 22rpx;
  color: #F57C00;
  background: #FFF3E0;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.warn-tag.sachet-optional {
  color: #1565C0;
  background: #E3F2FD;
}

.sachet-choice {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.sachet-opt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  background: #f9f9f9;
  gap: 12rpx;
}

.sachet-opt-icon  { font-size: 48rpx; }
.sachet-opt-label { font-size: 26rpx; color: #666; font-weight: 500; }

.sachet-opt.selected.clinic {
  border-color: #C62828;
  background: #FFEBEE;
}
.sachet-opt.selected.clinic .sachet-opt-label { color: #C62828; font-weight: 700; }

.sachet-opt.selected.shop {
  border-color: #2E7D32;
  background: #E8F5E9;
}
.sachet-opt.selected.shop .sachet-opt-label { color: #2E7D32; font-weight: 700; }

/* 底部操作 */
.bottom-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 24rpx 0;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.flex-1 { flex: 1; }
.flex-2 { flex: 2; }

/* 悬浮添加环节按钮：滚动时始终可见 */
.fab-add-step {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #2E7D32;
  color: #fff;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(46,125,50,0.35);
  z-index: 100;
}
.fab-icon { font-size: 32rpx; font-weight: 700; }
.fab-text { font-size: 24rpx; }

/* 步骤区域为空提示 */
.step-empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #aaa;
  font-size: 24rpx;
}

/* 自定义时间选择器弹窗 */
.time-picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.time-picker-popup {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 0 48rpx;
}
.time-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.time-picker-cancel { color: #999; font-size: 28rpx; padding: 8rpx 16rpx; }
.time-picker-confirm { color: #2E7D32; font-size: 28rpx; font-weight: 600; padding: 8rpx 16rpx; }
.time-picker-body {
  display: flex;
  height: 360rpx;
  position: relative;
}
.time-picker-col {
  flex: 1;
  height: 360rpx;
}
.time-picker-indicator {
  position: absolute;
  top: 50%;
  left: 0; right: 0;
  height: 72rpx;
  transform: translateY(-50%);
  border-top: 1rpx solid #e0e0e0;
  border-bottom: 1rpx solid #e0e0e0;
  pointer-events: none;
}
.time-picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
  height: 72rpx;
}
