<!-- pages/activity-edit/activity-edit.wxml -->
<!-- 复用创建页的 wxml，仅标题和底部按钮不同 -->
<view class="create-page">
  <scroll-view scroll-y class="form-scroll">

    <view class="edit-banner">
      <text class="edit-banner-text">🖊 修改内容将自动记录到修订日志</text>
    </view>

    <!-- 此处内容与 activity-create.wxml 完全一致，实际项目中建议抽取为组件 -->
    <!-- 为避免重复，此文件可 import activity-create 的模板 -->

    <view class="card form-section">
      <text class="section-title">基本信息</text>

      <view class="form-item">
        <text class="form-label required">活动时间</text>
        <picker mode="date" value="{{form.activityDate}}" bindchange="onDateChange">
          <view class="form-input picker-value {{!form.activityDate ? 'placeholder' : ''}}">
            {{form.activityDate || '请选择日期'}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label required">到店时间</text>
        <picker mode="time" value="{{form.arrivalTime}}" bindchange="onArrivalTimeChange">
          <view class="form-input picker-value {{!form.arrivalTime ? 'placeholder' : ''}}">
            {{form.arrivalTime || '请选择到店时间'}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label required">活动单位</text>
        <input class="form-input" value="{{form.activityUnit}}"
          bindinput="onInput" data-field="activityUnit" />
      </view>

      <view class="form-item">
        <text class="form-label required">活动地点</text>
        <input class="form-input" value="{{form.venue}}"
          bindinput="onInput" data-field="venue" />
      </view>

      <view class="form-item">
        <text class="form-label">活动人数</text>
        <input class="form-input" type="number" value="{{form.peopleCount}}"
          bindinput="onInput" data-field="peopleCount" />
      </view>

      <view class="form-item">
        <text class="form-label">业务体现</text>
        <input class="form-input" value="{{form.businessType}}"
          bindinput="onInput" data-field="businessType" />
      </view>

      <view class="form-item">
        <text class="form-label">场地使用</text>
        <textarea class="form-input form-textarea" value="{{form.venueUsage}}"
          bindinput="onInput" data-field="venueUsage" auto-height />
      </view>
    </view>

    <!-- 活动流程环节 -->
    <view class="card form-section step-section">
      <view class="section-header">
        <text class="section-title">活动流程</text>
        <view class="add-step-btn" bindtap="addStep"><text>＋ 添加环节</text></view>
      </view>

      <view class="step-form-list">
        <view class="step-form-item" wx:for="{{form.steps}}" wx:key="tempId">
          <view class="step-form-header">
            <text class="step-form-num">环节 {{index + 1}}</text>
            <view class="step-remove" bindtap="removeStep" data-index="{{index}}">✕</view>
          </view>
          <view class="form-item">
            <text class="form-label">环节名称</text>
            <input class="form-input" value="{{item.stepName}}"
              bindinput="onStepInput" data-index="{{index}}" data-field="stepName" />
          </view>
          <view class="step-time-row">
            <view class="form-item flex-half">
              <text class="form-label">开始时间</text>
              <view class="form-input picker-value {{!item.startTime ? 'placeholder' : ''}}"
                bindtap="openTimePicker"
                data-index="{{index}}" data-field="startTime">
                {{item.startTime || '09:00'}}
              </view>
            </view>
            <view class="step-time-sep">~</view>
            <view class="form-item flex-half">
              <text class="form-label">结束时间</text>
              <view class="form-input picker-value {{!item.endTime ? 'placeholder' : ''}}"
                bindtap="openTimePicker"
                data-index="{{index}}" data-field="endTime">
                {{item.endTime || '10:00'}}
              </view>
            </view>
          </view>
          <!-- 环节地点 -->
          <view class="form-item">
            <text class="form-label">地点</text>
            <picker mode="selector" range="{{venueOptions}}"
              value="{{item.venueIndex != null && item.venueIndex >= 0 ? item.venueIndex : 0}}"
              bindchange="onStepVenueChange" data-index="{{index}}">
              <view class="form-input picker-value">{{item.venue || '请选择地点'}}</view>
            </picker>
          </view>
          <view class="form-item">
            <text class="form-label">负责人</text>
            <!-- 管理员：部门+人员双列选择 -->
            <picker wx:if="{{canAssignOwner && isAdmin}}" mode="multiSelector" range="{{deptUserRange}}"
              value="{{item.ownerDeptValue}}"
              bindchange="onStepOwnerChange"
              bindcolumnchange="onStepOwnerColumnChange"
              data-index="{{index}}">
              <view class="form-input picker-value">{{item.ownerName || '请选择'}}</view>
            </picker>
            <!-- 有指派权限但非管理员：单列选择 -->
            <picker wx:elif="{{canAssignOwner}}" mode="selector" range="{{userList}}" range-key="name"
              value="{{item.ownerIndex}}" bindchange="onStepOwnerChange" data-index="{{index}}">
              <view class="form-input picker-value">{{item.ownerName || '请选择'}}</view>
            </picker>
            <!-- 无指派权限：只读 -->
            <view wx:else class="form-input picker-value read-only">{{item.ownerName || '未指派'}}</view>
          </view>
        </view>
      </view>

      <view wx:if="{{form.steps.length === 0}}" class="step-empty-tip">
        <text>暂无环节，点击右下角「＋添加环节」开始</text>
      </view>
    </view>

    <!-- 结算信息 -->
    <view class="card form-section">
      <text class="section-title">结算信息</text>
      <view class="form-item">
        <text class="form-label">结算方式</text>
        <input class="form-input" value="{{form.settlementMethod}}"
          bindinput="onInput" data-field="settlementMethod" />
      </view>
      <view class="form-item">
        <text class="form-label">费用合计（元）</text>
        <input class="form-input" type="digit" value="{{form.totalCost}}"
          bindinput="onInput" data-field="totalCost" />
      </view>
      <view class="form-item">
        <text class="form-label">活动对接人</text>
        <input class="form-input" value="{{form.contactPerson}}"
          bindinput="onInput" data-field="contactPerson" />
      </view>
      <view class="form-item">
        <text class="form-label required">活动预订人</text>
        <input wx:if="{{isAdmin}}" class="form-input" value="{{form.bookingPerson}}"
          bindinput="onInput" data-field="bookingPerson" />
        <view wx:else class="form-input picker-value">{{form.bookingPerson || '（自动填写）'}}</view>
      </view>
    </view>

    <!-- 客户关注信息 -->
    <view class="card form-section">
      <text class="section-title">客户特殊关注信息</text>
      <view class="form-item">
        <text class="form-label">民族 / 宗教</text>
        <input class="form-input" value="{{form.clientInfo.ethnicity}}"
          bindinput="onClientInput" data-field="ethnicity" />
      </view>
      <view class="form-item">
        <text class="form-label">年龄</text>
        <input class="form-input" value="{{form.clientInfo.age}}"
          bindinput="onClientInput" data-field="age" />
      </view>
      <view class="form-item">
        <text class="form-label">食物禁忌</text>
        <textarea class="form-input form-textarea" value="{{form.clientInfo.dietaryRestrictions}}"
          bindinput="onClientInput" data-field="dietaryRestrictions" auto-height />
      </view>
      <view class="form-item">
        <text class="form-label">重要接待需求</text>
        <textarea class="form-input form-textarea" value="{{form.clientInfo.specialRequirements}}"
          bindinput="onClientInput" data-field="specialRequirements" auto-height />
      </view>
    </view>

    <!-- 场地需求 -->
    <view class="card form-section">
      <text class="section-title">场地需求</text>
      <view class="need-toggle-grid">
        <view class="need-toggle {{form.venueNeeds.build ? 'active' : ''}}"
          bindtap="toggleNeed" data-field="build"><text class="need-icon">🏗</text><text>搭建</text></view>
        <view class="need-toggle {{form.venueNeeds.rehearsal ? 'active' : ''}}"
          bindtap="toggleNeed" data-field="rehearsal"><text class="need-icon">🎭</text><text>预演</text></view>
        <view class="need-toggle {{form.venueNeeds.power ? 'active' : ''}}"
          bindtap="toggleNeed" data-field="power"><text class="need-icon">⚡</text><text>接电</text></view>
        <view class="need-toggle {{form.venueNeeds.mainVisual ? 'active' : ''}}"
          bindtap="toggleNeed" data-field="mainVisual"><text class="need-icon">🖼</text><text>主视觉</text></view>
        <view class="need-toggle {{form.venueNeeds.filming ? 'active' : ''}}"
          bindtap="toggleNeed" data-field="filming"><text class="need-icon">🎬</text><text>拍摄/直播</text></view>
      </view>
    </view>

    <!-- 香囊（仅含香囊关键词时显示） -->
    <view class="card form-section sachet-section" wx:if="{{showSachet}}">
      <view class="section-header">
        <text class="section-title required">香囊账户确认</text>
        <text class="warn-tag">⚠ 必选</text>
      </view>
      <view class="sachet-choice">
        <view class="sachet-opt {{form.sachetAccount === 'clinic' ? 'selected clinic' : ''}}"
          bindtap="setSachet" data-val="clinic">
          <text class="sachet-opt-icon">🏥</text><text class="sachet-opt-label">医馆账户</text>
        </view>
        <view class="sachet-opt {{form.sachetAccount === 'shop' ? 'selected shop' : ''}}"
          bindtap="setSachet" data-val="shop">
          <text class="sachet-opt-icon">🏪</text><text class="sachet-opt-label">零号店账户</text>
        </view>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="bottom-actions">
      <button class="btn-primary" style="width:100%;" bindtap="saveEdit" loading="{{saving}}"
        wx:if="{{originalStatus !== 'draft'}}">
        保存修改
      </button>
      <block wx:else>
        <button class="btn-secondary flex-1" bindtap="saveEdit" loading="{{saving}}">保存草稿</button>
        <button class="btn-primary flex-2" bindtap="submitDraft" loading="{{submitting}}">提交活动</button>
      </block>
    </view>

    <view style="height: 120rpx;" />
  </scroll-view>

  <!-- 悬浮添加环节按钮：fixed定位，不受滚动影响 -->
  <view class="fab-add-step" bindtap="addStep" wx:if="{{form.steps.length > 0}}">
    <text class="fab-icon">＋</text>
    <text class="fab-text">添加环节</text>
  </view>

  <!-- 自定义时间选择弹窗 -->
  <view class="time-picker-mask" wx:if="{{showTimePicker}}" bindtap="closeTimePicker">
    <view class="time-picker-popup" catchtap="">
      <view class="time-picker-header">
        <view class="time-picker-cancel" bindtap="closeTimePicker">取消</view>
        <view class="time-picker-confirm" bindtap="confirmTimePicker">确定</view>
      </view>
      <view class="time-picker-body">
        <picker-view class="time-picker-col" value="{{timePickerValue}}" bindchange="onTimePickerChange">
          <picker-view-column>
            <view class="time-picker-item" wx:for="{{timeHours}}" wx:key="*this">{{item}} 时</view>
          </picker-view-column>
          <picker-view-column>
            <view class="time-picker-item" wx:for="{{timeMinutes}}" wx:key="*this">{{item}} 分</view>
          </picker-view-column>
        </picker-view>
        <view class="time-picker-indicator" />
      </view>
    </view>
  </view>
  <notify-overlay />

</view>
