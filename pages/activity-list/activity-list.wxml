<!-- pages/activity-list/activity-list.wxml -->
<view class="list-page">

  <!-- 顶部搜索与筛选 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索活动名称 / 单位"
        value="{{searchKey}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
    </view>
    <view class="filter-btn" bindtap="toggleFilter">
      <text>筛选</text>
      <text wx:if="{{activeFilters > 0}}" class="filter-badge">{{activeFilters}}</text>
    </view>
  </view>

  <!-- 日期筛选行 -->
  <view class="date-filter-row">
    <!-- 四列选择器：年/月/日/模式 -->
    <picker mode="multiSelector" range="{{multiSelectorRange}}" value="{{multiSelectorValue}}" bindchange="onMultiDateChange" bindcolumnchange="onMultiColumnChange">
      <view class="date-picker-chip {{filterDateMode ? 'active' : ''}}">
        <text class="date-chip-icon">📅</text>
        <text>{{filterDateLabel}}</text>
        <text wx:if="{{filterDateMode}}" class="date-chip-clear" catchtap="clearDateFilter">✕</text>
      </view>
    </picker>
    <view wx:if="{{filterStatus}}" class="filter-chip active" bindtap="clearStatusFilter">
      <text>{{filterStatusLabel}}</text>
      <text class="date-chip-clear">✕</text>
    </view>
    <view wx:if="{{filterBooker}}" class="filter-chip active" bindtap="clearBookerFilter">
      <text>{{filterBooker}}</text>
      <text class="date-chip-clear">✕</text>
    </view>
    <view wx:if="{{filterDateMode || filterStatus || filterBooker}}" class="clear-filter-chip" bindtap="clearAllFilters">
      <text>清除筛选</text>
    </view>
  </view>

  <!-- 统计条 -->
  <view class="stat-bar">
    <text class="stat-text">共 {{total}} 个活动</text>
    <view class="add-btn" bindtap="goCreate" wx:if="{{canCreate}}">
      <text class="add-icon">＋</text>
      <text>新建活动</text>
    </view>
  </view>

  <!-- 通知授权横幅 -->
  <view class="notify-banner" wx:if="{{showNotifyBanner}}" bindtap="onNotifyBannerTap">
    <text class="notify-banner-icon">🔔</text>
    <text class="notify-banner-text">点击开启通知授权</text>
    <text class="notify-banner-arrow">›</text>
  </view>

  <!-- 活动列表 -->
  <scroll-view
    class="activity-list"
    scroll-y
    enhanced
    bounces
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore"
  >
    <view wx:if="{{loading && activities.length === 0}}" class="loading-wrapper">
      <view class="loading-dot" />
    </view>

    <view wx:elif="{{activities.length === 0}}" class="empty-state">
      <text class="empty-icon">📋</text>
      <text>暂无活动</text>
      <text class="empty-sub">点击右上角「＋新建活动」开始</text>
    </view>

    <block wx:else>
      <view
        class="activity-card card"
        wx:for="{{activities}}"
        wx:key="id"
        data-id="{{item._id}}"
        bindtap="goDetail"
      >
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="activity-date-block">
            <text class="activity-month">{{item.activityMonth}}</text>
            <text class="activity-day">{{item.activityDay}}</text>
          </view>
          <view class="activity-meta">
            <text class="activity-unit">{{item.activityUnit}}</text>
            <text class="activity-time">{{item.activityDate}}{{item.arrivalTime ? ' ' + item.arrivalTime : ''}}</text>
          </view>
          <view class="card-right">
            <view class="tag {{item.statusClass}}">{{item.statusLabel}}</view>
            <text class="people-count">👥 {{item.peopleCount}}人</text>
          </view>
        </view>

        <view class="divider" />

        <!-- 场地 -->
        <view class="venue-row">
          <text class="info-label">📍</text>
          <text class="info-value">{{item.venue}}</text>
        </view>

        <!-- 活动环节列表（含顺序进度圆点） -->
        <view class="steps-list" wx:if="{{item.steps && item.steps.length > 0}}">
          <view class="step-row" wx:for="{{item.steps}}" wx:for-item="step" wx:key="id">
            <view class="step-progress-dot {{step.status}}"></view>
            <text class="step-name">{{step.stepName}}</text>
            <text class="step-venue" wx:if="{{step.venue}}">📍{{step.venue}}</text>
            <text class="step-time" wx:if="{{step.startTime}}">{{step.startTime}}{{step.endTime ? '~' + step.endTime : ''}}</text>
          </view>
        </view>
        <view class="venue-row" wx:else>
          <text class="info-label">💼</text>
          <text class="info-value">{{item.businessType || '暂无环节'}}</text>
        </view>

        <!-- 凭证状态 -->
        <view class="voucher-row">
          <view class="voucher-item {{item.depositVoucher ? 'uploaded' : 'missing'}}">
            <text>{{item.depositVoucher ? '✓' : '✗'}} 订金</text>
          </view>
          <view class="voucher-item {{item.billVoucher ? 'uploaded' : 'missing'}}">
            <text>{{item.billVoucher ? '✓' : '✗'}} 账单</text>
          </view>
          <view class="voucher-item {{item.settlementVoucher ? 'uploaded' : 'missing'}}">
            <text>{{item.settlementVoucher ? '✓' : '✗'}} 结算</text>
          </view>
        </view>

        <!-- 预订人 -->
        <view class="footer-row">
          <text class="footer-meta">预订人：{{item.bookingPerson}}</text>
          <text class="footer-meta">对接人：{{item.contactPerson}}</text>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{hasMore}}">
        <text>加载更多...</text>
      </view>
      <view class="no-more" wx:elif="{{activities.length > 0}}">
        <text>—— 已全部加载 ——</text>
      </view>
    </block>
  </scroll-view>

  <register-dialog visible="{{showRegister}}" bind:success="onRegisterSuccess" />

</view>
