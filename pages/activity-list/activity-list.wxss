/* pages/activity-list/activity-list.wxss */
.list-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
  gap: 10rpx;
}

.search-icon { font-size: 28rpx; color: #999; }

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 52rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: #E8F5E9;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #2E7D32;
  position: relative;
}

.filter-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #D32F2F;
  color: #fff;
  border-radius: 50%;
  width: 28rpx;
  height: 28rpx;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 统计条 */
.stat-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 28rpx;
  background: #fff;
}

.stat-text { font-size: 24rpx; color: #888; }

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #2E7D32;
  color: #fff;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.add-icon { font-size: 32rpx; font-weight: 300; }

/* 活动列表 */
.activity-list {
  flex: 1;
  overflow: hidden;
}

/* 活动卡片 */
.activity-card {
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.activity-date-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #E8F5E9;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  min-width: 80rpx;
}

.activity-month { font-size: 22rpx; color: #2E7D32; }
.activity-day   { font-size: 36rpx; font-weight: 700; color: #2E7D32; line-height: 1.1; }

.activity-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.activity-unit  { font-size: 30rpx; font-weight: 600; color: #222; }
.activity-time  { font-size: 24rpx; color: #888; }

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.people-count { font-size: 22rpx; color: #999; }

/* 卡片正文 */
.card-body {
  margin: 12rpx 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.info-label { font-size: 24rpx; }
.info-value  { font-size: 26rpx; color: #444; flex: 1; }

/* 环节进度 */
.steps-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 8rpx 0;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.step-dot.done  { background: #2E7D32; }
.step-dot.doing { background: #F57C00; }
.step-dot.todo  { background: #cccccc; }

/* 凭证状态 */
.voucher-row {
  display: flex;
  gap: 12rpx;
  margin: 12rpx 0 8rpx;
}

.voucher-item {
  flex: 1;
  text-align: center;
  padding: 8rpx 0;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.voucher-item.uploaded { background: #E8F5E9; color: #2E7D32; }
.voucher-item.missing  { background: #FFEBEE; color: #D32F2F; }

/* 卡片底部 */
.footer-row {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.footer-meta { font-size: 22rpx; color: #aaa; }

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #bbb;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 8rpx;
  display: block;
}
