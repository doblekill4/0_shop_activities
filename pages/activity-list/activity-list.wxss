/* pages/activity-list/activity-list.wxss */
.list-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 日期筛选行 */
.date-filter-row {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #ffffff;
  gap: 16rpx;
}

.date-picker-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border: 1rpx solid #e0e0e0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.date-picker-chip.active {
  background: #E8F5E9;
  border-color: #2E7D32;
  color: #2E7D32;
}

.date-chip-icon { font-size: 24rpx; }

.date-chip-clear {
  margin-left: 4rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #C8E6C9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #2E7D32;
}

.filter-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border: 1rpx solid #e0e0e0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.filter-chip.active {
  background: #E3F2FD;
  border-color: #1565C0;
  color: #1565C0;
}

.filter-chip.active .date-chip-clear {
  background: #BBDEFB;
  color: #1565C0;
}

.clear-filter-chip {
  padding: 10rpx 20rpx;
  background: #FFF3E0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #E65100;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
  gap: 10rpx;
}

.search-icon { font-size: 28rpx; color: #999; }

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 52rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: #E8F5E9;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #2E7D32;
  position: relative;
}

.filter-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #D32F2F;
  color: #fff;
  border-radius: 50%;
  width: 28rpx;
  height: 28rpx;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 统计条 */
.stat-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 28rpx;
  background: #fff;
}

.stat-text { font-size: 24rpx; color: #888; }


.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #2E7D32;
  color: #fff;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.add-icon { font-size: 32rpx; font-weight: 300; }

/* 活动列表 */
.activity-list {
  flex: 1;
  overflow: hidden;
}

/* 活动卡片 */
.activity-card {
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.activity-date-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #E8F5E9;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  min-width: 80rpx;
}

.activity-month { font-size: 22rpx; color: #2E7D32; }
.activity-day   { font-size: 36rpx; font-weight: 700; color: #2E7D32; line-height: 1.1; }

.activity-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.activity-unit  { font-size: 30rpx; font-weight: 600; color: #222; }
.activity-time  { font-size: 24rpx; color: #888; }

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.people-count { font-size: 22rpx; color: #999; }

/* 场地行 */
.venue-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin: 12rpx 0;
}

.info-label { font-size: 24rpx; }
.info-value  { font-size: 26rpx; color: #444; flex: 1; }

/* 活动环节列表 */
.steps-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin: 8rpx 0 12rpx;
}

.step-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 环节进度圆点 */
.step-progress-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.step-progress-dot.done  { background: #2E7D32; }
.step-progress-dot.doing { background: #F57C00; }
.step-progress-dot.todo  { background: #d0d0d0; }

/* 环节名称 */
.step-name {
  font-size: 24rpx;
  color: #444;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 环节地点徽章 */
.step-venue {
  font-size: 20rpx;
  color: #1565C0;
  background: #E3F2FD;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 环节时间 */
.step-time {
  font-size: 22rpx;
  color: #aaa;
  flex-shrink: 0;
}

/* 凭证状态 */
.voucher-row {
  display: flex;
  gap: 12rpx;
  margin: 12rpx 0 8rpx;
}

.voucher-item {
  flex: 1;
  text-align: center;
  padding: 8rpx 0;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.voucher-item.uploaded { background: #E8F5E9; color: #2E7D32; }
.voucher-item.missing  { background: #FFEBEE; color: #D32F2F; }

/* 卡片底部 */
.footer-row {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.footer-meta { font-size: 22rpx; color: #aaa; }

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #bbb;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 8rpx;
  display: block;
}

/* 状态标签（与 activity-detail 保持一致） */
.tag-active    { background: #E8F5E9; color: #2E7D32; padding: 4rpx 16rpx; border-radius: 12rpx; font-size: 22rpx; }
.tag-completed { background: #E3F2FD; color: #1565C0; padding: 4rpx 16rpx; border-radius: 12rpx; font-size: 22rpx; }
.tag-pending   { background: #FFF3E0; color: #E65100; padding: 4rpx 16rpx; border-radius: 12rpx; font-size: 22rpx; }
.tag-settled   { background: #F3E5F5; color: #7B1FA2; padding: 4rpx 16rpx; border-radius: 12rpx; font-size: 22rpx; }
