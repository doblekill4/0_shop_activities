<!-- pages/login/login.wxml - 微信风格授权登录 + 群入口识别 -->
<view class="login-page">

  <!-- Step 0: 授权登录 -->
  <view class="login-step" wx:if="{{step === 'auth'}}">
    <view class="login-logo-wrap">
      <image class="login-logo" src="/assets/images/logo.png" mode="aspectFit" />
    </view>
    <view class="login-brand">
      <text class="brand-name">知嘛健康零号店</text>
      <text class="brand-desc">活动预定管理系统</text>
    </view>

    <view class="login-card">
      <view class="card-icon">🔐</view>
      <text class="card-title">授权登录</text>
      <text class="card-desc">授权获取你的微信信息，用于活动管理和身份识别</text>

      <button class="btn-auth" bindtap="handleAuth" loading="{{loading}}">
        <text wx:if="{{!loading}}">微信授权登录</text>
        <text wx:else>授权中...</text>
      </button>

      <text class="agreement-text">登录即表示同意使用条款和隐私政策</text>
    </view>

    <!-- 审核快捷登录：仅审核模式下显示 -->
    <view class="review-login" wx:if="{{reviewMode}}">
      <view class="review-divider"><text>审核快捷通道</text></view>
      <button class="btn-review" bindtap="reviewQuickLogin" loading="{{reviewLoading}}">
        审核测试登录（一键进入）
      </button>
      <text class="review-hint">内部管理工具，审核人员专用入口</text>
    </view>
  </view>

  <!-- Step 1: 获取微信资料 -->
  <view class="login-step" wx:if="{{step === 'wechatInfo'}}">
    <view class="profile-header">
      <text class="profile-title">获取微信资料</text>
      <text class="profile-desc">一次点击即可获取你的微信头像和昵称</text>
    </view>

    <view class="profile-card">
      <view class="avatar-section">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview {{avatarUrl ? 'has-avatar' : ''}}"
            src="{{avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
        </button>
        <text class="avatar-hint">👆 点击使用微信头像</text>
      </view>

      <view class="profile-item">
        <text class="profile-label">昵称</text>
        <input class="profile-input" type="nickname" placeholder="点击自动填入微信昵称"
          value="{{nickname}}" bindinput="onNicknameInput" maxlength="20" />
      </view>

      <button class="btn-save-profile" bindtap="confirmWechatInfo">
        下一步
      </button>
    </view>
  </view>

  <!-- Step 2: 填写姓名和部门 -->
  <view class="login-step" wx:if="{{step === 'profile'}}">
    <view class="profile-header">
      <text class="profile-title">完善信息</text>
      <text class="profile-desc" wx:if="{{isEmployee}}">
        🟢 已识别为门店群成员，将自动获得员工权限
      </text>
    </view>

    <view class="profile-card">
      <!-- 头像昵称预览（只读） -->
      <view class="wechat-preview">
        <image class="avatar-preview has-avatar" src="{{avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
        <text class="wechat-nickname">{{nickname || '微信用户'}}</text>
      </view>

      <view class="profile-item">
        <text class="profile-label required">姓名</text>
        <input class="profile-input" placeholder="请填写真实姓名" focus="{{true}}"
          value="{{name}}" bindinput="onNameInput" maxlength="20" />
      </view>

      <view class="profile-item" wx:if="{{isEmployee}}">
        <text class="profile-label required">工号</text>
        <input class="profile-input" placeholder="请输入工号"
          value="{{employeeId}}" bindinput="onEmployeeIdInput" maxlength="20" />
      </view>

      <view class="profile-item">
        <text class="profile-label required">部门</text>
        <picker mode="selector" range="{{departmentNames}}" value="{{departmentIndex}}" bindchange="onDepartmentChange">
          <view class="profile-picker {{department ? '' : 'placeholder'}}">
            {{department || '请选择部门'}}
          </view>
        </picker>
      </view>

      <button class="btn-save-profile" bindtap="saveProfile" loading="{{saving}}">
        <text wx:if="{{!saving}}">完成注册</text>
        <text wx:else>注册中...</text>
      </button>
    </view>
  </view>

</view>
