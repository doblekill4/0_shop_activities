/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1B5E20 0%, #2E7D32 40%, #43A047 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  background-color: rgba(255,255,255,0.15);
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.app-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 10rpx;
}

.login-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin: 0;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
  display: block;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #888;
  display: block;
  margin-bottom: 48rpx;
}

.btn-wechat {
  width: 100%;
  background-color: #07C160;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 28rpx;
}

.btn-wechat-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.login-tip {
  font-size: 22rpx;
  color: #bbb;
  display: block;
  text-align: center;
}

/* 注册表单样式 */
.register-form {
  width: 100%;
  margin-bottom: 32rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-item .label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.form-item .input {
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
}

.form-item .input:focus {
  border-color: #2E7D32;
  background-color: #ffffff;
}
