/* pages/activity-detail/notification-sheet.wxss */
.notif-page {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.notif-sheet {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.notif-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.notif-title { font-size: 32rpx; font-weight: 700; color: #222; }
.notif-close { font-size: 40rpx; color: #ccc; padding: 8rpx; }

.notif-body {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.notif-activity {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.notif-label { font-size: 24rpx; color: #888; flex-shrink: 0; }
.notif-value { font-size: 28rpx; color: #333; font-weight: 600; flex: 1; }
.notif-date { font-size: 24rpx; color: #999; }

.notif-section {
  margin-bottom: 24rpx;
}

.owner-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.owner-chip {
  padding: 8rpx 20rpx;
  background: #E3F2FD;
  color: #1565C0;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.subscribe-card {
  padding: 20rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #6D4C41;
  margin: 12rpx 0;
}

.subscribe-card.done {
  background: #E8F5E9;
  color: #2E7D32;
}

.btn-sub {
  width: 100%;
  background: #FFF3E0;
  color: #E65100;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid #FFE0B2;
}

.btn-sub[disabled] {
  background: #E8F5E9;
  color: #2E7D32;
  border-color: #C8E6C9;
}

.notif-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 48rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  border: none;
}

.btn-send {
  flex: 2;
  background: #2E7D32;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

/* 发送结果渐隐提示 */
.result-toast {
  position: fixed;
  top: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.78);
  padding: 24rpx 40rpx;
  border-radius: 16rpx;
  flex-direction: row;
  align-items: center;
  opacity: 0;
  transition: opacity 0.3s;
  z-index: 400;
}
.result-toast.show { opacity: 1; }
.result-icon { font-size: 36rpx; }
.result-text { font-size: 28rpx; color: #fff; margin-left: 16rpx; }
