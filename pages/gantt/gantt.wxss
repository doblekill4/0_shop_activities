/* pages/gantt/gantt.wxss - 按天/小时视图，左侧活动名列冻结 */
.gantt-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
}

/* 日期导航 */
.gantt-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #2E7D32;
  flex-shrink: 0;
}
.nav-arrow {
  color: #ffffff;
  font-size: 60rpx;
  font-weight: 300;
  width: 60rpx;
  text-align: center;
  line-height: 1;
}
.nav-title { text-align: center; }
.nav-date { font-size: 26rpx; color: #ffffff; font-weight: 600; display: block; }

/* 主体垂直滚动容器 */
.gantt-main-scroll {
  flex: 1;
  height: 0;
}

.gantt-body {
  display: flex;
}

/* ---- 左侧冻结列 ---- */
.frozen-col {
  width: 160rpx;
  flex-shrink: 0;
  border-right: 1rpx solid #e0e0e0;
  background: #ffffff;
  z-index: 3;
}

.frozen-header {
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  border-bottom: 1rpx solid #e0e0e0;
  font-weight: 600;
}

.frozen-row {
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 0 12rpx;
}

.frozen-cell {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 8rpx 0;
}

.label-unit { font-size: 22rpx; font-weight: 600; color: #333; line-height: 1.3; word-break: break-all; }
.label-info { font-size: 20rpx; color: #666; margin-top: 2rpx; }
.label-date { font-size: 18rpx; color: #888; }

/* 状态标签（与活动列表页颜色一致） */
.status-tag {
  font-size: 18rpx;
  font-weight: 500;
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
}
.status-tag.tag-pending { color: #E65100; background: #FFF3E0; }
.status-tag.tag-settled { color: #7B1FA2; background: #F3E5F5; }

/* ---- 右侧横向滚动区域 ---- */
.gantt-scroll-x {
  flex: 1;
  min-width: 0;
}

.gantt-scroll-inner {
  /* width 通过内联样式动态设置 */
}

/* 小时表头 */
.hour-header {
  display: flex;
  height: 60rpx;
  background: #f5f5f5;
  position: sticky;
  top: 0;
  z-index: 2;
  border-bottom: 1rpx solid #e0e0e0;
}

.hour-cell {
  /* width 由内联样式动态设置（hourCellWidth） */
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 4rpx;
  font-size: 20rpx;
  color: #888;
  border-right: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

/* 活动行 */
.gantt-rows { }

.gantt-row {
  display: flex;
  min-height: 80rpx;
  position: relative;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 小时网格（相对定位容器）*/
.hour-cells {
  position: relative;
  display: flex;
  flex: 1;
}

.hour-cell-bg {
  /* width 由内联样式动态设置（hourCellWidth） */
  flex-shrink: 0;
  border-right: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

/* 环节进度条 - 颜色由内联 barStyle 控制，此处只负责形状和排版 */
.step-bar {
  position: absolute;
  height: 52rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  padding: 0 10rpx;
  overflow: hidden;
  z-index: 2;
  white-space: nowrap;
  font-size: 18rpx;
  box-sizing: border-box;
}

.step-label { font-size: 18rpx; color: inherit; font-weight: 500; }

/* 加载 / 空状态 */
.loading-wrapper, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  width: 100%;
}
.empty-icon { font-size: 60rpx; margin-bottom: 16rpx; }

/* 图例 */
.legend-bar {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 16rpx;
  background: #fafafa;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.legend-dot.pending { background: #90CAF9; }
.legend-dot.doing   { background: #FFCC02; }
.legend-dot.done    { background: #A5D6A7; }

/* 筛选开关 */
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-bottom: 1rpx solid #e0e0e0;
  flex-shrink: 0;
}

.filter-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
}

/* 今日场地使用（简洁列表） */
.venue-card {
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  overflow: hidden;
}
.venue-card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #2E7D32;
  padding: 16rpx 24rpx;
  background: #E8F5E9;
  border-bottom: 1rpx solid #C8E6C9;
}
.venue-group {
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.venue-group:last-child {
  border-bottom: none;
}
.venue-group-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.venue-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 0 6rpx 16rpx;
  border-left: 3rpx solid #E3F2FD;
  margin: 4rpx 0;
}
.venue-item-time {
  font-size: 22rpx;
  color: #1565C0;
  font-weight: 500;
  flex-shrink: 0;
  min-width: 120rpx;
}
.venue-item-unit {
  font-size: 24rpx;
  color: #444;
}
.venue-item-step {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}
