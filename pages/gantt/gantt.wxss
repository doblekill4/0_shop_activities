/* pages/gantt/gantt.wxss - 按天/小时视图，左侧活动名列冻结 */
.gantt-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
}

/* 日期导航 */
.gantt-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #2E7D32;
  flex-shrink: 0;
}
.nav-arrow {
  color: #ffffff;
  font-size: 60rpx;
  font-weight: 300;
  width: 60rpx;
  text-align: center;
  line-height: 1;
}
.nav-title { text-align: center; }
.nav-date { font-size: 26rpx; color: #ffffff; font-weight: 600; display: block; }

/* 主体：外层纵向滚动容器 */
.gantt-body-scroll {
  flex: 1;
  height: 0; /* 让 flex:1 正确生效 */
}

.gantt-body {
  display: flex;
  min-height: 100%;
}

/* ---- 左侧冻结列 ---- */
.frozen-col {
  width: 160rpx;
  flex-shrink: 0;
  border-right: 1rpx solid #e0e0e0;
  background: #ffffff;
  z-index: 3;
}

.frozen-header {
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  border-bottom: 1rpx solid #e0e0e0;
  font-weight: 600;
}

.frozen-row {
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 0 12rpx;
}

.frozen-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.label-unit { font-size: 22rpx; font-weight: 600; color: #333; }
.label-date { font-size: 18rpx; color: #888; }

/* ---- 右侧横向滚动区域 ---- */
.gantt-scroll-x {
  flex: 1;
  min-width: 0;
}

.gantt-scroll-inner {
  /* width 通过内联样式动态设置 */
}

/* 小时表头 */
.hour-header {
  display: flex;
  height: 60rpx;
  background: #f5f5f5;
  position: sticky;
  top: 0;
  z-index: 2;
  border-bottom: 1rpx solid #e0e0e0;
}

.hour-cell {
  width: 200rpx; /* PX_PER_HOUR = 200rpx */
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #888;
  border-right: 1rpx solid #f0f0f0;
}

/* 活动行 */
.gantt-rows { }

.gantt-row {
  display: flex;
  min-height: 80rpx;
  position: relative;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 小时网格（相对定位容器）*/
.hour-cells {
  position: relative;
  display: flex;
  flex: 1;
}

.hour-cell-bg {
  width: 200rpx; /* 与 PX_PER_HOUR 保持一致 */
  flex-shrink: 0;
  border-right: 1rpx solid #f5f5f5;
}

/* 环节进度条 - 颜色由内联 barStyle 控制，此处只负责形状和排版 */
.step-bar {
  position: absolute;
  height: 52rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  padding: 0 10rpx;
  overflow: hidden;
  z-index: 2;
  white-space: nowrap;
  font-size: 18rpx;
  box-sizing: border-box;
}

.step-label { font-size: 18rpx; color: inherit; font-weight: 500; }

/* 加载 / 空状态 */
.loading-wrapper, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  width: 100%;
}
.empty-icon { font-size: 60rpx; margin-bottom: 16rpx; }

/* 图例 */
.legend-bar {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 16rpx;
  background: #fafafa;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.legend-dot.pending { background: #90CAF9; }
.legend-dot.doing   { background: #FFCC02; }
.legend-dot.done    { background: #A5D6A7; }

/* 筛选开关 */
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-bottom: 1rpx solid #e0e0e0;
  flex-shrink: 0;
}

.filter-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
}
